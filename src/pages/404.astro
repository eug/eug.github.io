---
import PageLayout from "@/layouts/Base.astro";

const description = "Oops! It looks like this page is lost in space!";
const title = "Oops! You found a missing page!";
const meta = {
	description,
	title,
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">404 | Oops something went wrong</h1>
	<p class="mb-8">Please use the navigation to find your way back</p>
</PageLayout>
